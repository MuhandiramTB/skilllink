# ===========================================================================
# SkillLink LK — environment template. Copy to apps/api/.env and apps/web/.env.local
# ===========================================================================

# --- Database (local PostgreSQL 18 + PostGIS) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skilllink"

# --- API ---
API_PORT=4000
NODE_ENV="development"            # production REQUIRES the secrets below to be real
JWT_ACCESS_SECRET="dev-access-secret-change-me"   # MUST change outside dev (boot fails otherwise)
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
CORS_ORIGIN="http://localhost:3000"               # never "*" in production

# --- Auth verifier selection ---
# mock = accept "mock:<+94…>" tokens (DEV ONLY; refused in production).
# firebase = verify real Firebase ID tokens via the Admin SDK.
AUTH_VERIFIER="mock"

# --- Firebase (OTP) — required when AUTH_VERIFIER=firebase ---
# Provide credentials via EITHER GOOGLE_APPLICATION_CREDENTIALS (path to a service
# account JSON) OR FIREBASE_SERVICE_ACCOUNT (the JSON inline).  Run: npm i firebase-admin
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# FIREBASE_SERVICE_ACCOUNT=""

# --- Payments ---
PAYMENT_GATEWAY="mock"                            # mock | payhere | genie
PAYMENT_MOCK_SECRET="dev-pay-secret"              # MUST change outside dev; webhook HMAC key
PAYMENT_COMMISSION_RATE="0.12"

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# --- Third-party (later sprints) ---
# CLOUDINARY_URL=""
# GOOGLE_MAPS_API_KEY=""
# PAYHERE_MERCHANT_ID=""
